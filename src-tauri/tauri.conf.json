{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Pressfield",
	"version": "0.1.0",
	"identifier": "com.saagar.pressfield",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Pressfield",
				"width": 960,
				"height": 680,
				"minWidth": 640,
				"minHeight": 480,
				"theme": "Dark"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"macOS": {
			"signingIdentity": "Developer ID Application: SAAGAR I PATEL (3TGZFKFNA4)",
			"hardenedRuntime": true
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
